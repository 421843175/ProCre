<view class="content"><view class="header" style="margin-top:220rpx;"><image src="../../static/loginimg/projectcreatethis.jpg"></image></view><view class="list"><view class="list-call" style="margin-top:100rpx;"><image class="img" src="/static/loginimg/1.png"></image><input class="sl-input" type="number" placeholder="输入邮箱" data-event-opts="{{[['input',[['__set_model',['','mail','$event',[]]]]]]}}" value="{{mail}}" bindinput="__e"/></view><view class="list-call"><image class="img" src="/static/loginimg/2.png"></image><input class="sl-input" type="text" maxlength="32" placeholder="输入密码" password="true" data-event-opts="{{[['input',[['__set_model',['','password','$event',[]]]]]]}}" value="{{password}}" bindinput="__e"/></view></view><view class="button-login" style="margin-top:120rpx;" hover-class="button-hover" data-event-opts="{{[['tap',[['bindLogin']]]]}}" bindtap="__e"><text>登录</text></view><view class="agreenment" style="margin-top:120rpx;"><navigator url="forget" open-type="navigate">忘记密码</navigator><text>|</text><navigator url="reg" open-type="navigate">注册账户</navigator></view></view>