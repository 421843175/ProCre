<view class="content"><view class="header" style="margin-top:80rpx;"><image src="../../static/loginimg/projectcreatethis.jpg"></image></view><view class="list"><view class="list-call" style="margin-top:60rpx;"><image class="img" src="/static/loginimg/1.png"></image><input class="sl-input" type="text" placeholder="邮箱" data-event-opts="{{[['input',[['__set_model',['','mail','$event',[]]]]]]}}" value="{{mail}}" bindinput="__e"/></view><view class="list-call"><image class="img" src="/static/loginimg/2.png"></image><input class="sl-input" type="text" maxlength="32" placeholder="登录密码" password="{{!showPassword}}" data-event-opts="{{[['input',[['__set_model',['','password','$event',[]]]]]]}}" value="{{password}}" bindinput="__e"/><image class="img" src="{{showPassword?'/static/loginimg/op.png':'/static/loginimg/cl.png'}}" data-event-opts="{{[['tap',[['display',['$event']]]]]}}" bindtap="__e"></image></view><view class="list-call"><image class="img" src="/static/loginimg/3.png"></image><input class="sl-input" type="number" maxlength="6" placeholder="验证码" data-event-opts="{{[['input',[['__set_model',['','code','$event',[]]]]]]}}" value="{{code}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['getcode',['$event']]]]]}}" class="{{['yzm',(second>0)?'yzms':'']}}" bindtap="__e">{{yanzhengma}}</view></view><view class="list-call"><image class="img" src="/static/loginimg/4.png"></image><input class="sl-input" type="text" maxlength="12" placeholder="申请码" data-event-opts="{{[['input',[['__set_model',['','invitation','$event',[]]]]]]}}" value="{{invitation}}" bindinput="__e"/></view></view><view class="button-login" hover-class="button-hover" data-event-opts="{{[['tap',[['bindLogin',['$event']]]]]}}" bindtap="__e"><text>注册</text></view><view class="agreement"><image src="{{agreement==true?'/static/loginimg/ty1.png':'/static/loginimg/ty0.png'}}" data-event-opts="{{[['tap',[['agreementSuccess',['$event']]]]]}}" bindtap="__e"></image><text data-event-opts="{{[['tap',[['agreementSuccess',['$event']]]]]}}" bindtap="__e">同意</text><navigator url="agreement?id=1" open-type="navigate">《木星开发用户协议》</navigator></view></view>