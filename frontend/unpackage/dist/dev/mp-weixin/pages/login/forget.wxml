<view class="content"><view class="list"><view class="tishi" style="margin-top:120rpx;">若您忘记了密码，可在此重新设置新密码。</view><view class="list-call" style="margin-top:100rpx;"><image class="img" src="/static/loginimg/1.png"></image><input class="sl-input" type="text" placeholder="请输入邮箱" data-event-opts="{{[['input',[['__set_model',['','mail','$event',[]]]]]]}}" value="{{mail}}" bindinput="__e"/></view><view class="list-call" style="margin-top:100rpx;"><image class="img" src="/static/loginimg/2.png"></image><input class="sl-input" type="text" maxlength="32" placeholder="请输入新密码" password="{{!showPassword}}" data-event-opts="{{[['input',[['__set_model',['','password','$event',[]]]]]]}}" value="{{password}}" bindinput="__e"/><image class="img" src="{{showPassword?'/static/loginimg/op.png':'/static/loginimg/cl.png'}}" data-event-opts="{{[['tap',[['display',['$event']]]]]}}" bindtap="__e"></image></view><view class="list-call" style="margin-top:100rpx;"><image class="img" src="/static/loginimg/3.png"></image><input class="sl-input" type="number" maxlength="6" placeholder="验证码" data-event-opts="{{[['input',[['__set_model',['','code','$event',[]]]]]]}}" value="{{code}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['getcode',['$event']]]]]}}" class="{{['yzm',(second>0)?'yzms':'']}}" bindtap="__e">{{yanzhengma}}</view></view></view><view class="button-login" style="margin-top:120rpx;" hover-class="button-hover" data-event-opts="{{[['tap',[['bindLogin']]]]}}" bindtap="__e"><text>修改密码</text></view></view>